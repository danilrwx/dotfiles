{
  "enabled": true,
  "mode": "interactive",
  "network": {
    "block": false,
    "allowedDomains": [
      "api.github.com:443",
      "github.com:443",
      "gitlab.com:443"
    ]
  },
  "enableWeakerNetworkIsolation": true,
  "filesystem": {
    "allowRead": [
      ".",
      "~/w",
      "~/.pi",
      "/opt/homebrew"
    ],
    "allowWrite": [
      "/tmp",
      "/private/tmp",
      "/private/var/folders",
      "~/w",
      "~/.pi"
    ],
    "allowReadWrite": [
      "."
    ],
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.kube",
      "~/.kubeconfigs",
      "~/.gnupg",
      "~/.docker",
      "~/.npmrc",
      "~/.config/gcloud",
      "~/.local/share/keyrings"
    ],
    "denyWrite": [
      "~/.ssh",
      "~/.aws",
      "~/.kube",
      "~/.kubeconfigs",
      "~/.gnupg",
      "~/.docker",
      "~/.npmrc",
      "~/.gitconfig",
      "~/.zshrc",
      "~/.bashrc",
      "~/.profile",
      "~/.bash_profile"
    ]
  }
}
